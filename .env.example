# ---- Copy to .env and fill in the values ----

# Public host name served by Caddy.
# "localhost" for local testing (self-signed cert); a real domain in production.
PUBLIC_HOST=localhost

# PostgreSQL credentials (used by both the postgres container and the app).
POSTGRES_DB=structura
POSTGRES_USER=structura
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing key — at least 32 characters of random data.
# Generate one:  openssl rand -base64 48
JWT_SIGNING_KEY=change-me-to-a-long-random-secret-of-at-least-32-chars

# First administrator account, created automatically on first start.
# The password must be changed at first sign-in.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!Initial1

# Break-glass admin password reset (use only if you are locked out of the admin account).
# Set RESET_ADMIN_PASSWORD (and optionally RESET_ADMIN_EMAIL to target a specific admin),
# restart the app, sign in with it, set a new password — then REMOVE these and restart.
# RESET_ADMIN_EMAIL=admin@example.com
# RESET_ADMIN_PASSWORD=

# Optional: seed a full demo (users, project, 60 processed records, assignments, approvals).
# Refused in Production unless SEED_DEMO_FORCE=true. Leave false for a clean install.
SEED_DEMO=false

# Optional: outbound HTTP proxy for AI providers and Telegram in restricted networks.
# e.g. http://user:pass@proxy:8080  or  socks5://proxy:1080
OUTBOUND_PROXY_URL=

# The Telegram bot token is NOT set here — configure it in the app under
# Settings → Telegram (it is encrypted at rest). Notifications/Mini App need a public HTTPS URL.
